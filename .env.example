# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit actual secrets.

# ── Supabase ─────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only — bypasses Row Level Security. Never expose to the client
# or prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Integrations ─────────────────────────────────────────
# n8n webhook that appends "Book a Demo" submissions to Google Sheets.
NEXT_PUBLIC_DEMO_WEBHOOK_URL=your_n8n_webhook_url
# Shared secret checked on inbound requests from the Google Opal / n8n
# content pipeline before a blog digest is accepted.
OPAL_AGENT_SECRET=your_custom_secret_for_opal
